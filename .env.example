# Шаблон окружения. Скопируй в .env и подставь свои значения:
#   cp .env.example .env
# Реальный .env в git НЕ попадает (см. .gitignore). Этот файл — коммитится.

# --- PostgreSQL ---
POSTGRES_DB=gardengram
POSTGRES_USER=gg_user
POSTGRES_PASSWORD=change-me

# localhost — если Django запускается вручную с хоста (порт проброшен из контейнера).
# db        — если Django запускается внутри docker-compose.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
