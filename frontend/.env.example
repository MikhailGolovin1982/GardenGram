# Базовый адрес API бэкенда (Django), вместе с /api/v1.
# Это ШАБЛОН (коммитится в git). Реальное значение — в .env.local (в git НЕ идёт).
#
# В Codespaces сгенерируй .env.local командой (из папки frontend/):
#   printf 'VITE_API_BASE_URL=https://%s-8000.%s/api/v1\n' \
#     "$CODESPACE_NAME" "${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN:-app.github.dev}" \
#     > .env.local
#
# Либо впиши адрес вручную, заменив <CODESPACE_NAME> на имя своего Codespace:
VITE_API_BASE_URL=https://<CODESPACE_NAME>-8000.app.github.dev/api/v1
